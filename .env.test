# Test-only environment. Points at the throwaway Postgres in
# docker-compose.test.yml. The database name MUST contain "test" — the test
# harness refuses to run otherwise, so it can never touch dev/prod data.
DATABASE_URL="postgresql://bolvi:bolvi@localhost:5433/bolvi_care_test?schema=public"
DIRECT_URL="postgresql://bolvi:bolvi@localhost:5433/bolvi_care_test?schema=public"

# Deterministic secrets so auth/token tests are reproducible.
AUTH_SECRET="test-secret-not-for-production"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="test"

# Dummy Stripe keys so lib/stripe instantiates a client in tests. The secret
# key is never used against the network; the webhook secret lets tests sign
# payloads with stripe.webhooks.generateTestHeaderString for signature and
# idempotency checks.
STRIPE_SECRET_KEY="sk_test_dummy"
STRIPE_WEBHOOK_SECRET="whsec_test_dummy"
